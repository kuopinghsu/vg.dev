g++ -Iri/include -Iri/include/VG -Iri/include/EGL -Iri/src -DOPENVG_STATIC_LIBRARY -DEGL_STATIC_LIBRARY -D_GNU_SOURCE -O2 -std=c++11 -Wall -fno-strict-aliasing -fpermissive -Wno-int-to-pointer-cast -Wno-catch-value -c ri/src/riImage.cpp -o build/riImage.o
g++ -Iri/include -Iri/include/VG -Iri/include/EGL -Iri/src -DOPENVG_STATIC_LIBRARY -DEGL_STATIC_LIBRARY -D_GNU_SOURCE -O2 -std=c++11 -Wall -fno-strict-aliasing -fpermissive -Wno-int-to-pointer-cast -Wno-catch-value -c ri/src/riMath.cpp -o build/riMath.o
g++ -Iri/include -Iri/include/VG -Iri/include/EGL -Iri/src -DOPENVG_STATIC_LIBRARY -DEGL_STATIC_LIBRARY -D_GNU_SOURCE -O2 -std=c++11 -Wall -fno-strict-aliasing -fpermissive -Wno-int-to-pointer-cast -Wno-catch-value -c ri/src/riMiniEGL.cpp -o build/riMiniEGL.o
g++ -Iri/include -Iri/include/VG -Iri/include/EGL -Iri/src -DOPENVG_STATIC_LIBRARY -DEGL_STATIC_LIBRARY -D_GNU_SOURCE -O2 -std=c++11 -Wall -fno-strict-aliasing -fpermissive -Wno-int-to-pointer-cast -Wno-catch-value -c ri/src/riPath.cpp -o build/riPath.o
