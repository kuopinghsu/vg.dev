mkdir -p build
gcc -Iri/include -Iri/include/VG -Iri/include/EGL -Iri/src -DOPENVG_STATIC_LIBRARY -DEGL_STATIC_LIBRARY -D_GNU_SOURCE -O2 -std=c99  -Wall -c samples/tiger/main.c -o build/main.o
gcc -Iri/include -Iri/include/VG -Iri/include/EGL -Iri/src -DOPENVG_STATIC_LIBRARY -DEGL_STATIC_LIBRARY -D_GNU_SOURCE -O2 -std=c99  -Wall -c samples/tiger/tiger.c -o build/tiger.o
g++ -Iri/include -Iri/include/VG -Iri/include/EGL -Iri/src -DOPENVG_STATIC_LIBRARY -DEGL_STATIC_LIBRARY -D_GNU_SOURCE -O2 -std=c++11 -Wall -fno-strict-aliasing -fpermissive -Wno-int-to-pointer-cast -Wno-catch-value -c ri/src/riApi.cpp -o build/riApi.o
g++ -Iri/include -Iri/include/VG -Iri/include/EGL -Iri/src -DOPENVG_STATIC_LIBRARY -DEGL_STATIC_LIBRARY -D_GNU_SOURCE -O2 -std=c++11 -Wall -fno-strict-aliasing -fpermissive -Wno-int-to-pointer-cast -Wno-catch-value -c ri/src/riContext.cpp -o build/riContext.o
